# GitHub
GITHUB_TOKEN=                              # Personal access token (read-only scope sufficient)

# Milvus  (env_nested_delimiter="__" — double underscore separates nested fields)
# Option 1: Milvus Lite (embedded, no Docker — stores in a local .db file)
MILVUS__URI=./data/milvus.db
# Option 2: Local Milvus via Docker — docker run -p 19530:19530 milvusdb/milvus:latest standalone
# MILVUS__URI=http://localhost:19530
# Option 3: Milvus Cloud / Zilliz
# MILVUS__URI=https://your-cluster.zillizcloud.com
MILVUS__TOKEN=                             # Milvus Cloud token (leave blank for local)

# LLM backend: ollama | openai | anthropic
LLM__BACKEND=ollama
LLM__OLLAMA__BASE_URL=http://localhost:11434
LLM__OLLAMA__MODEL=llama3.1:8b
LLM__OPENAI__MODEL=gpt-4o-mini
LLM__ANTHROPIC__MODEL=claude-haiku-4-5-20251001

# API keys (standard flat names — loaded directly by the SDK clients)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Embeddings
EMBEDDINGS__MODEL=all-MiniLM-L6-v2        # sentence-transformers model name
EMBEDDINGS__DEVICE=                        # auto-detected: mps | cuda | cpu

# Observability
OBSERVABILITY__MLFLOW__ENABLED=true
OBSERVABILITY__MLFLOW__TRACKING_URI=http://localhost:5025
OBSERVABILITY__PHOENIX__ENABLED=true
OBSERVABILITY__PHOENIX__COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
OBSERVABILITY__METRICS_DB=data/metrics.db

# Query cache
CACHE__TTL_SECONDS=3600
CACHE__MAX_SIZE=1000
# CACHE__BACKEND=redis
# CACHE__REDIS_URL=redis://localhost:6379

# RAG tuning
RAG__TOP_K=10
RAG__MIN_SCORE=0.15
RAG__MAX_COLLECTIONS_PER_QUERY=3
